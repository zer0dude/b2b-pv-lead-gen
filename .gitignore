# --- Python ---
__pycache__/
*.py[cod]
*.pyo
.venv/
.uv/
*.egg-info/
dist/
build/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Large geodata (download instructions in data/raw/README.md) ---
# Shapefile components
data/raw/**/*.shp
data/raw/**/*.dbf
data/raw/**/*.shx
data/raw/**/*.prj
data/raw/**/*.cpg
data/raw/**/*.sbn
data/raw/**/*.sbx
data/raw/**/*.qmd
# Source zip archives
data/raw/**/*.zip
# Extracted Tatsächliche Nutzung folders
data/raw/tatsaechliche-nutzung/tn_*/
# Decompressed ASC rasters (re-generated from .gz)
data/raw/sunshine-duration/*.asc

# --- Processed outputs (generated by pipeline) ---
data/processed/*
!data/processed/.gitkeep

